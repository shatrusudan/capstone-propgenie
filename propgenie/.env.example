# ==========================================
# PROPGENIE ENVIRONMENT VARIABLES TEMPLATE
# ==========================================

# 1. Google Cloud Platform Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-east1
GOOGLE_GENAI_USE_VERTEXAI=True

# 2. Firebase & Storage Configuration
# Cloud Run automatically authenticates via service accounts, but for local testing:
# FIREBASE_CREDENTIALS_JSON=/absolute/path/to/firebase-credentials.json
STORAGE_BUCKET_NAME=your-gcs-storage-bucket

# 3. Next.js Dashboard UI Integration (FastAPI CORS)
# Comma-separated list of origins allowed to call the backend APIs
ALLOW_ORIGINS=http://localhost:3000,https://your-firebase-dashboard-app.web.app

# 4. WhatsApp Business API (via MCP)
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_API_TOKEN=your-whatsapp-permanent-system-token

# 5. Razorpay / UPI Integration (via MCP)
RAZORPAY_KEY_ID=rzp_live_yourkeyid
RAZORPAY_KEY_SECRET=yourkeysecret

# 6. Gmail API Integration (via MCP)
GMAIL_SENDER_EMAIL=owner.email@gmail.com
# OAuth2 client credentials for sending emails securely:
GMAIL_CLIENT_ID=your-gmail-oauth-client-id
GMAIL_CLIENT_SECRET=your-gmail-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-oauth-refresh-token

# 7. Google Calendar Integration (via MCP)
GOOGLE_CALENDAR_ID=primary
